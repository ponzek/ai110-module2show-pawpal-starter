classDiagram
    %% PawPal+ UML Class Diagram — Phase 1 Draft

    class Owner {
        +str name
        +int available_minutes
        +list~str~ preferences
        +add_pet(pet: Pet) None
        +set_availability(minutes: int) None
        +get_pets() list~Pet~
    }

    class Pet {
        +str name
        +str species
        +int age
        +list~str~ special_needs
        +list~Task~ tasks
        +add_task(task: Task) None
        +remove_task(title: str) None
        +get_tasks() list~Task~
    }

    class Task {
        +str title
        +int duration_minutes
        +str priority
        +str category
        +bool is_recurring
        +str preferred_time
        +is_valid() bool
        +__lt__(other: Task) bool
    }

    class Scheduler {
        +Owner owner
        +list~Pet~ pets
        +int total_minutes
        +generate_schedule() list~dict~
        +sort_by_priority(tasks: list~Task~) list~Task~
        +detect_conflicts(schedule: list~dict~) list~str~
        +filter_by_time(tasks: list~Task~, available: int) list~Task~
        +explain_plan(schedule: list~dict~) str
    }

    Owner "1" --> "1..*" Pet : owns
    Pet "1" --> "0..*" Task : has
    Scheduler "1" --> "1" Owner : plans for
    Scheduler "1" --> "1..*" Pet : schedules tasks for
    Scheduler ..> Task : processes
